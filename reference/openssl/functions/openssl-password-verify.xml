    </thead>
    <tbody>
     <row>
      <entry>8.4.0</entry>
      <entry>
       関数が追加されました。
      </entry>
     </row>
    </tbody>
   </tgroup>
  </informaltable>
 </refsect1>

 <refsect1 role="examples">
  &reftitle.examples;
  <example>
   <title><function>openssl_password_verify</function> の例</title>
   <programlisting role="php">
<![CDATA[
<?php
$hash = openssl_password_hash('argon2id', 'my-secret-password');

if (openssl_password_verify('argon2id', 'my-secret-password', $hash)) {
    echo 'Password matches.';
} else {
    echo 'Password does not match.';
}
?>
]]>
   </programlisting>
  </example>
 </refsect1>

 <refsect1 role="seealso">
  &reftitle.seealso;
  <para>
   <simplelist>
    <member><function>openssl_password_hash</function></member>
    <member><function>password_verify</function></member>
   </simplelist>
  </para>
 </refsect1>

</refentry>
